{
  "agents": {
    "defaults": {
      "workspace": "./workspace",
      "model": "glm-4.5",
      "provider": "zhipu",
      "maxTokens": 8192,
      "temperature": 0.1,
      "maxToolIterations": 200,
      "memoryWindow": 100
    }
  },
  "providers": {
    "acp": {
      "agent": "claude",
      "modelId": "qwen3.5-plus",
      "cwd": "./workspace",
      "sessionName": "0xclaw",
      "timeoutSec": 1800,
      "acpxCommand": "",
      "approveAll": true
    },
    "custom": {
      "apiKey": "${ZAI_API_KEY}",
      "apiBase": "https://api.z.ai/api/paas/v4"
    },
    "zhipu": {
      "apiKey": "${ZAI_API_KEY}",
      "apiBase": "https://api.z.ai/api/paas/v4"
    },
    "flock": {
      "apiKey": "${FLOCK_API_KEY}",
      "apiBase": "https://api.flock.io/v1",
      "extraHeaders": {
        "x-litellm-api-key": "${FLOCK_API_KEY}"
      }
    }
  },
  "subagents": {
    "coding": {
      "backend": "claude_code",
      "fallbackBackend": "default_llm"
    },
    "claudeCode": {
      "agent": "claude",
      "modelId": "qwen3.5-plus",
      "cwd": "./workspace/hackathon/project",
      "sessionName": "0xclaw-coder",
      "timeoutSec": 1800,
      "acpxCommand": "",
      "approveAll": true
    }
  },
  "channels": {
    "whatsapp": {
      "enabled": false,
      "bridgeUrl": "ws://localhost:3001",
      "bridgeToken": "${WHATSAPP_BRIDGE_TOKEN}",
      "allowFrom": []
    },
    "telegram": {
      "enabled": true,
      "token": "${TELEGRAM_BOT_TOKEN}",
      "allowFrom": [],
      "replyToMessage": true
    }
  },
  "tools": {
    "exec": {
      "timeout": 120
    },
    "web": {
      "search": {
        "apiKey": "${BRAVE_API_KEY}"
      }
    }
  },
  "gateway": {
    "heartbeat": {
      "enabled": true,
      "intervalS": 21600
    }
  }
}
